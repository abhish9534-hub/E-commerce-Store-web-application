{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A handmade product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "integer" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "isFeatured": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "description", "category", "images", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "User": {
      "title": "User",
      "description": "Platform user",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "viewHistory": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["customer", "admin"] }
      },
      "required": ["email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "stripeSessionId": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "type": { "type": "string", "enum": ["percentage", "fixed"] },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discount", "type", "expiresAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Handmade products" },
    "categories": { "schema": "Category", "description": "Product categories" },
    "users": { "schema": "User", "description": "User profiles" },
    "orders": { "schema": "Order", "description": "Customer orders" },
    "coupons": { "schema": "Coupon", "description": "Discount coupons" },
    "products/{productId}/reviews": { "schema": "Review", "description": "Product reviews" }
  }
}
